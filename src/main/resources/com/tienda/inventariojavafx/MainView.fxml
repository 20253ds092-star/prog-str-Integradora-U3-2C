<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tienda.inventariojavafx.controller.MainController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Inventario de Productos" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar:"/>
        <TextField fx:id="txtBusqueda" promptText="Por código o nombre..." HBox.hgrow="ALWAYS"/>
    </HBox>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn text="Código" prefWidth="100"/>
            <TableColumn text="Nombre" prefWidth="200"/>
            <TableColumn text="Precio" prefWidth="100"/>
            <TableColumn text="Stock" prefWidth="100"/>
            <TableColumn text="Categoría" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER">
        <Button text="Nuevo Producto" onAction="#agregarProducto" style="-fx-background-color: #4c90af; -fx-text-fill: white;"/>
        <Button text="Editar Seleccionado" onAction="#editarProducto" style="-fx-background-color: #d79a4b; -fx-text-fill: white;"/>
        <Button text="Eliminar Seleccionado" onAction="#eliminarProducto" style="-fx-background-color: #F44336; -fx-text-fill: white;"/>
    </HBox>
</VBox>