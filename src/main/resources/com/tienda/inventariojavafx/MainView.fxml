<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tienda.inventariojavafx.controller.MainController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label styleClass="label-header" text="Inventario de Productos">
      <effect>
         <InnerShadow />
      </effect></Label>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Buscar:" />
        <TextField fx:id="txtBusqueda" promptText="Por código o nombre..." HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="100" text="Código" />
            <TableColumn prefWidth="200" text="Nombre" />
            <TableColumn prefWidth="100" text="Precio" />
            <TableColumn prefWidth="100" text="Stock" />
            <TableColumn prefWidth="150" text="Categoría" />
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="15">
        <Button onAction="#agregarProducto" styleClass="btn-nuevo" text="Nuevo Producto" />
        <Button onAction="#editarProducto" styleClass="btn-editar" text="Editar Seleccionado" />
        <Button onAction="#eliminarProducto" styleClass="btn-eliminar" text="Eliminar Seleccionado" />
    </HBox>
</VBox>
